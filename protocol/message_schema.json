{
  "version": "2.0",
  "description": "Digital Human Streaming Protocol",
  "messages": [
    {
      "type": "audio_chunk",
      "direction": "client -> server",
      "fields": {
        "type": "audio_chunk",
        "session_id": "string",
        "timestamp": "int64",
        "seq": "int",
        "data": "base64"
      }
    },
    {
      "type": "tts_chunk",
      "direction": "server -> client",
      "fields": {
        "type": "tts_chunk",
        "session_id": "string",
        "seq": "int",
        "data": "base64",
        "end": "boolean"
      }
    },
    {
      "type": "interrupt",
      "direction": "client -> server",
      "fields": {
        "type": "interrupt",
        "session_id": "string"
      }
    }
  ],
  "data_types": {
    "AudioChunk": {
      "SessionID": "string",
      "Seq": "int",
      "Data": "[]byte"
    },
    "TextChunk": {
      "SessionID": "string",
      "Text": "string",
      "Final": "boolean"
    },
    "TTSChunk": {
      "SessionID": "string",
      "Seq": "int",
      "Data": "[]byte",
      "End": "boolean"
    }
  },
  "pipeline": {
    "stages": ["asr", "agent", "llm", "tts"],
    "data_flow": "audio → asr → agent → llm → tts → output"
  }
}